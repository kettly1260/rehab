{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["node"],
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "*.js",
    "globals.d.ts",
    "storage/**/*.js",
    "scripts/**/*.mjs",
    "test/**/*.mjs"
  ],
  "exclude": [
    "build/**",
    "**/*.bak",
    "node_modules"
  ]
}
